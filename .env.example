# Copy to ~/.katana-bot/env (chmod 600) and fill in. NEVER commit a filled copy.
# Code defaults are SAFE (DRY_RUN=1). The executor only sends when DRY_RUN=0 AND KT_CONTRACT set.

# --- required for live ---
KT_CONTRACT=                 # KatanaLiquidator address from bot/deploy.sh
# Key: prefer a 600-perm file at ~/.katana-bot/key (KT_KEYFILE) over inline.
# KT_PRIVATE_KEY=0x...        # avoid — leaks into process env / history
KT_KEYFILE=/home/claude-agent/.katana-bot/key

# --- safety (start here) ---
DRY_RUN=1                    # 1 = log only (default). Flip to 0 ONLY when ready to go live.
KT_MIN_PROFIT_USD=20         # off-chain net floor AND on-chain minProfit gate (stables)
KT_MIN_DEBT_USD=500          # ignore dust positions
KT_MAX_DAILY_GAS_USD=5       # kill-switch (gas is ~$0.005/liq, so this is generous)
KT_MAX_CONSEC_REVERTS=3      # kill-switch
KT_DEDUP_SEC=300             # don't re-fire the same target within 5 min

# --- sizing / routing ---
KT_MAX_SLIPPAGE=0.008        # slippage floor sent to Sushi (0.8%)
KT_MAX_IMPACT=0.02           # chunk down if a swap's price impact exceeds this (2%)

# --- discovery ---
KT_DISCOVERY=api                        # api (default; Morpho indexer, no getLogs scan) | logs
KT_API_HF_CEILING=1.15                  # watch ceiling for the indexer candidate set

# --- infra ---
KT_RPC=https://rpc.katana.network      # write endpoint (sign+broadcast)
# KT_WRITE_RPCS=https://rpc.katanarpc.com,https://katana.gateway.tenderly.co
#                                      # fallback write endpoints, rotated on transport failure
# KT_READ_RPC=http://127.0.0.1:8545    # override reads (e.g. a local anvil fork for a dry live test)
KT_CHAIN_ID=747474
# KT_CHECKPOINT_BLOCK=                  # ONLY for KT_DISCOVERY=logs; the api path needs no checkpoint
KT_POLL_SEC=20
KT_GAS_LIMIT=1800000
KT_PRIORITY_GWEI=0.001                  # OP-stack sequencers likely order by tip — bid up when
                                        # contending for a large close (pennies vs the bonus)
KT_RAW_TX=1                             # 1 = in-process eth_account (default; pip install -r
                                        # requirements.txt); 0 = cast subprocess fallback
KT_LIQ_LOG_WINDOW=2000                  # blocks of real Liquidate events per API pass -> race
                                        # telemetry ("who beat us"); 0 = off

# --- alerts (recommended: the kill-switch is silent without them) ---
KT_CHAT_ID=                             # telegram chat id for fire/revert/kill-switch alerts
# KT_TG_TOKEN=                          # bot token (or the telegram channel env file is used)
KT_HEARTBEAT_SEC=86400
