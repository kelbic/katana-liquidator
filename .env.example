# Copy to ~/.katana-bot/env (chmod 600) and fill in. NEVER commit a filled copy.
# Code defaults are SAFE (DRY_RUN=1). The executor only sends when DRY_RUN=0 AND KT_CONTRACT set.

# --- required for live ---
KT_CONTRACT=                 # KatanaLiquidator address from bot/deploy.sh
# Key: prefer a 600-perm file at ~/.katana-bot/key (KT_KEYFILE) over inline.
# KT_PRIVATE_KEY=0x...        # avoid — leaks into process env / history
KT_KEYFILE=/home/claude-agent/.katana-bot/key

# --- safety (start here) ---
DRY_RUN=1                    # 1 = log only (default). Flip to 0 ONLY when ready to go live.
KT_MIN_PROFIT_USD=20         # off-chain net floor AND on-chain minProfit gate (stables)
KT_MIN_DEBT_USD=500          # ignore dust positions
KT_MAX_DAILY_GAS_USD=5       # kill-switch (gas is ~$0.005/liq, so this is generous)
KT_MAX_CONSEC_REVERTS=3      # kill-switch
KT_DEDUP_SEC=300             # don't re-fire the same target within 5 min

# --- sizing / routing ---
KT_MAX_SLIPPAGE=0.008        # slippage floor sent to Sushi (0.8%)
KT_MAX_IMPACT=0.02           # chunk down if a swap's price impact exceeds this (2%)

# --- discovery ---
KT_DISCOVERY=api                        # api (default; Morpho indexer, no getLogs scan) | logs
KT_API_HF_CEILING=1.15                  # watch ceiling for the indexer candidate set

# --- infra ---
KT_RPC=https://rpc.katana.network      # write endpoint (sign+broadcast)
# KT_WRITE_RPCS=https://rpc.katanarpc.com,https://katana.gateway.tenderly.co
#                                      # fallback write endpoints, rotated on transport failure
# KT_READ_RPC=http://127.0.0.1:8545    # override reads (e.g. a local anvil fork for a dry live test)
KT_CHAIN_ID=747474
# KT_CHECKPOINT_BLOCK=                  # ONLY for KT_DISCOVERY=logs; the api path needs no checkpoint
KT_POLL_SEC=20
KT_GAS_LIMIT=1800000
KT_PRIORITY_GWEI=0.001                  # OP-stack sequencers likely order by tip — bid up when
                                        # contending for a large close (pennies vs the bonus)
KT_RAW_TX=1                             # 1 = in-process eth_account (default; pip install -r
                                        # requirements.txt); 0 = cast subprocess fallback
KT_LIQ_LOG_WINDOW=2000                  # blocks of real Liquidate events per API pass -> race
                                        # telemetry ("who beat us"); 0 = off

# --- EOA gas-balance guard (defaults are sane; see STATE.md funding table) ---
# KT_BALANCE_CHECK_SEC=600              # re-check cadence; alert when below the fire-readiness
# KT_BALANCE_FIRES=3                    # floor = max(1 max-bid envelope, K fires at default tip)

# --- predictive fast path (defaults ON and measured-sane; bot/fastpath.py) ---
KT_PREDICTIVE_POLL=1                    # block-phase-locked detect + pre-armed fire; 0 = the
                                        # classic fixed hot cadence
# KT_ARM_HF=1.002                       # pre-arm (quote+preflight+pre-sign in the idle zone)
# KT_ARM_MAX_N=4                        #   targets with 1 <= HF < KT_ARM_HF, biggest first
# KT_ARM_QUOTE_TTL=2.5                  # armed quote/signature freshness (s)
# KT_BLIND_FIRE=1                       # skip preflight in the critical path — ONLY at the
                                        # default tip (lost race ~$0.001); bid targets always
                                        # preflight (a reverted bid burns the bid). 0 = never
# KT_PREDICT_WINDOW=0.80                # idle zone length after a block detect (s)
# KT_PREDICT_STEP=0.018                 # armed-zone eth_blockNumber tight-poll period (s)
# KT_PREDICT_SLACK=0.75                 # give up SLACK after the expected boundary -> re-sync

# --- mempool same-block backrun (bot/mempool.py; ADDITIVE, needs KT_PREDICTIVE_POLL=1) ---
KT_MEMPOOL=1                            # watch the Conduit public mempool for oracle pushes and
                                        # backrun them into the SAME block (matched tip). 0 = off
KT_MEMPOOL_SHADOW=1                     # default ON: do everything EXCEPT the send, log MEMPOOL
                                        # lines to measure same-block feasibility (zero spend)
# KT_MEMPOOL_LIVE=0                     # flip to real firing: set SHADOW=0 AND LIVE=1 after you
                                        # have reviewed the shadow data. Only fires at the low
                                        # matched oracle tip (a miss reverts for ~$0.01 of gas)
# KT_MEMPOOL_SEND_MS=216               # measured one-way write to the sequencer (feasibility)
# KT_MEMPOOL_CUTOFF_MS=300             # same-block inclusion cutoff after the boundary
# KT_MEMPOOL_MAX_TIP_GWEI=0.5          # matched tip above this keeps preflight (never blind-high)
# KT_MEMPOOL_SEND_URL=                 # same-block write endpoint (default = KT_RPC)
# KT_MEMPOOL_WSS_URL=wss://rpc.katanarpc.com    # Conduit node (only endpoint with a mempool/WSS)
# KT_MEMPOOL_HTTP_URL=https://rpc.katanarpc.com # dedicated read lane for pending-tx bodies

# --- alerts (recommended: the kill-switch is silent without them) ---
KT_CHAT_ID=                             # telegram chat id for fire/revert/kill-switch alerts
# KT_TG_TOKEN=                          # bot token (or the telegram channel env file is used)
KT_HEARTBEAT_SEC=86400
# KT_RACE_ALERT_MIN_USD=                # only PING competitor races whose bonus >= this (default
#                                       # = KT_MIN_PROFIT_USD). ALL races still logged + counted;
#                                       # unpriceable races fail open (still ping). Quiet mode.
# KT_RACE_ALERT_MAX=5                   # cap race pings per pass (a cascade can't firehose TG)
